{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "Socials",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "socials": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SocialMedia"
      }
    }
  },
  "required": [
    "$schema",
    "socials"
  ],
  "additionalProperties": false,
  "$defs": {
    "SocialMedia": {
      "id": "SocialMedia",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "isFontIcon": {
          "type": "boolean"
        },
        "link": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "label",
        "icon",
        "link"
      ],
      "additionalProperties": false
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "DocsNavigationMenu",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "menuItems": {
      "$ref": "#/$defs/DocsMenuItems"
    }
  },
  "required": [
    "$schema",
    "menuItems"
  ],
  "additionalProperties": false,
  "$defs": {
    "DocsMenuItems": {
      "id": "DocsMenuItems",
      "type": "array",
      "items": {
        "anyOf": [
          {
            "$ref": "#/$defs/DocsNavigationCategory"
          },
          {
            "$ref": "#/$defs/DocsNavigationItem"
          }
        ]
      }
    },
    "DocsNavigationCategory": {
      "id": "DocsNavigationCategory",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "category"
        },
        "label": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DocsNavigationItem"
          }
        }
      },
      "required": [
        "label",
        "icon",
        "children"
      ],
      "additionalProperties": false
    },
    "DocsNavigationItem": {
      "id": "DocsNavigationItem",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "item"
        },
        "label": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "label",
        "url"
      ],
      "additionalProperties": false
    }
  }
}
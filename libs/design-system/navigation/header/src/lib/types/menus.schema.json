{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "HeaderMenus",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "menus": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/HeaderMenu"
      }
    }
  },
  "required": [
    "$schema",
    "menus"
  ],
  "additionalProperties": false,
  "$defs": {
    "HeaderMenu": {
      "id": "HeaderMenu",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "menu"
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/HeaderMenuGroup"
              },
              {
                "$ref": "#/$defs/HeaderMenuDivider"
              }
            ]
          }
        }
      },
      "required": [
        "type",
        "id",
        "label",
        "items"
      ],
      "additionalProperties": false
    },
    "HeaderMenuGroup": {
      "id": "HeaderMenuGroup",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "group"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "external": {
          "type": "boolean"
        },
        "target": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/HeaderMenuSubGroup"
              },
              {
                "$ref": "#/$defs/HeaderMenuItem"
              }
            ]
          }
        }
      },
      "required": [
        "type",
        "label",
        "url"
      ],
      "additionalProperties": false
    },
    "HeaderMenuSubGroup": {
      "id": "HeaderMenuSubGroup",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "subgroup"
        },
        "label": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/HeaderMenuItem"
          }
        }
      },
      "required": [
        "type",
        "label",
        "items"
      ],
      "additionalProperties": false
    },
    "HeaderMenuItem": {
      "id": "HeaderMenuItem",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "item"
        },
        "label": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "external": {
          "type": "boolean"
        },
        "target": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "label",
        "url"
      ],
      "additionalProperties": false
    },
    "HeaderMenuDivider": {
      "id": "HeaderMenuDivider",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "divider"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    }
  }
}
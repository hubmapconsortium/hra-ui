{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "HubmapMenu",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/HubmapMenuGroup"
      }
    }
  },
  "required": [
    "$schema",
    "groups"
  ],
  "additionalProperties": false,
  "$defs": {
    "HubmapMenuGroup": {
      "id": "HubmapMenuGroup",
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/HubmapMenuItem"
          }
        }
      },
      "required": [
        "label",
        "items"
      ],
      "additionalProperties": false
    },
    "HubmapMenuItem": {
      "id": "HubmapMenuItem",
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "label",
        "description",
        "icon",
        "url"
      ],
      "additionalProperties": false
    }
  }
}
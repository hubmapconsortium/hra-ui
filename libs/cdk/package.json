{
  "name": "@hra-ui/cdk",
  "version": "1.1.0",
  "peerDependencies": {
    "@angular/common": "^21.1.4",
    "@angular/core": "^21.1.4",
    "@ngxs/store": "^21.0.0",
    "@hra-ui/utils": "*",
    "@angular/cdk": "^21.1.4",
    "rxjs": "^7.8.2",
    "@hra-ui/common": "1.1.0",
    "zod": "^4.1.3",
    "@angular/router": "^21.1.4",
    "js-yaml": "^4.1.0",
    "immer": "^11.1.4"
  },
  "sideEffects": false,
  "module": "fesm2022/hra-ui-cdk.mjs",

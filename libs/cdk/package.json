{
  "name": "@hra-ui/cdk",
  "version": "1.1.0",
  "peerDependencies": {
    "@angular/common": "^20.2.1",
    "@angular/core": "^20.2.1",
    "@ngxs/store": "^20.1.0",
    "@hra-ui/utils": "*",
    "@angular/cdk": "^20.2.0",
    "rxjs": "^7.8.2",
    "@hra-ui/common": "1.1.0",
    "zod": "^4.1.3",
    "@angular/router": "^20.2.1",
    "js-yaml": "^4.1.0",
    "immer": "^10.1.1"
  },
  "sideEffects": false,
  "module": "fesm2022/hra-ui-cdk.mjs",
  "typings": "index.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./index.d.ts",
      "default": "./fesm2022/hra-ui-cdk.mjs"
    },
    "./content-template": {
      "types": "./content-template/index.d.ts",
      "default": "./fesm2022/hra-ui-cdk-content-template.mjs"
    },
    "./injectors": {
      "types": "./injectors/index.d.ts",
      "default": "./fesm2022/hra-ui-cdk-injectors.mjs"
    },
    "./breakpoints": {
      "types": "./breakpoints/index.d.ts",
      "default": "./fesm2022/hra-ui-cdk-breakpoints.mjs"
    },
    "./platform-location": {
      "types": "./platform-location/index.d.ts",
      "default": "./fesm2022/hra-ui-cdk-platform-location.mjs"
    },
    "./state": {
      "types": "./state/index.d.ts",
      "default": "./fesm2022/hra-ui-cdk-state.mjs"
    },
    "./styling": {
      "types": "./styling/index.d.ts",
      "default": "./fesm2022/hra-ui-cdk-styling.mjs"
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  }
}
{
  "name": "ccf-shared",
  "version": "4.1.0",
  "peerDependencies": {
    "@angular/common": "^21.1.4",
    "@angular/core": "^21.1.4",
    "@angular/material": "^21.1.4",
    "@math.gl/core": "^3.5.5",
    "@ngxs/store": "^21.0.0",
    "rxjs": "^7.8.2",
    "ts-cacheable": "^1.0.6",
    "@angular-ru/ngxs": "^18.11.0",
    "@hra-api/ng-client": "^0.19.0",
    "@hra-ui/design-system": "1.1.0",
    "@angular-ru/cdk": "^18.11.0",
    "@hra-ui/common": "1.1.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "module": "fesm2022/ccf-shared.mjs",
  "typings": "types/ccf-shared.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./types/ccf-shared.d.ts",
      "default": "./fesm2022/ccf-shared.mjs"
    },
    "./rxjs-ext": {
      "types": "./types/ccf-shared-rxjs-ext.d.ts",
      "default": "./fesm2022/ccf-shared-rxjs-ext.mjs"
    },
    "./rxjs-ext/operators": {
      "types": "./types/ccf-shared-rxjs-ext-operators.d.ts",
      "default": "./fesm2022/ccf-shared-rxjs-ext-operators.mjs"
    },
    "./web-components": {
      "types": "./types/ccf-shared-web-components.d.ts",
      "default": "./fesm2022/ccf-shared-web-components.mjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "prepublishOnly": "node --eval \"console.error('ERROR: Trying to publish a package that has been compiled in full compilation mode. This is not allowed.\\nPlease delete and rebuild the package with partial compilation mode, before attempting to publish.\\n')\" && exit 1"
  }
}
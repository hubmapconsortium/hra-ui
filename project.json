{
  "name": "hra-ui",
  "targets": {
    "global-test-coverage-report": {
      "command": "node tools/scripts/create-coverage-report.mjs ./coverage",
      "cache": true,
      "inputs": [
        {
          "dependentTasksOutputFiles": "**/coverage-summary.json"
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/coverage-summary.json"],
      "dependsOn": [
        {
          "projects": "*",
          "target": "test",
          "params": "forward"
        }
      ]
    },
    "local-registry": {
      "executor": "@nx/js:verdaccio",
      "options": {
        "port": 4873,
        "config": ".verdaccio/config.yml",
        "storage": "tmp/local-registry/storage"
      }
    }
  }
}

{
  "name": "medical-illustration",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/medical-illustration/src",
  "prefix": "hra",
  "tags": ["type:app", "project:ftu", "webcomponent"],
  "metadata": {
    "version": "0.6.0"
  },
  "targets": {
    "build": {
      "executor": "@nx/angular:application",
      "options": {
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/medical-illustration/public"
          }
        ],
        "polyfills": ["zone.js"]
      },
      "configurations": {
        "staging": {
          "fileReplacements": [
            {
              "replace": "apps/medical-illustration/src/environments/environment.ts",
              "with": "apps/medical-illustration/src/environments/environment.staging.ts"
            }
          ]
        },
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/medical-illustration/src/environments/environment.ts",
              "with": "apps/medical-illustration/src/environments/environment.prod.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "executor": "@nx/angular:dev-server"
    },
    "build-webcomponent": {
      "command": "node tools/scripts/bundle-scripts.mjs dist/apps/medical-illustration/browser/"
    }
  }
}

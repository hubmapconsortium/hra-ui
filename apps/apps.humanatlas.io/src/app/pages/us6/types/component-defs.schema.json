{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "ComponentDefs",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "defs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ComponentDef"
      }
    }
  },
  "required": [
    "$schema",
    "defs"
  ],
  "additionalProperties": false,
  "$defs": {
    "ComponentDef": {
      "id": "ComponentDef",
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/ComponentDefId"
        },
        "productTitle": {
          "type": "string"
        },
        "webComponentName": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "previewImage": {
          "type": "string"
        },
        "embedAs": {
          "type": "string",
          "enum": [
            "inline",
            "overlay",
            "external"
          ]
        },
        "docLink": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "productTitle",
        "webComponentName",
        "description",
        "previewImage",
        "embedAs",
        "docLink"
      ],
      "additionalProperties": false
    },
    "ComponentDefId": {
      "id": "ComponentDefId",
      "type": "string"
    }
  }
}
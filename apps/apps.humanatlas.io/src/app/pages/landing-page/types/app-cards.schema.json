{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "AppCards",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "tabs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AppCardsTab"
      }
    }
  },
  "required": [
    "$schema",
    "tabs"
  ],
  "additionalProperties": false,
  "$defs": {
    "AppCardsTab": {
      "id": "AppCardsTab",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AppCardsSection"
          }
        }
      },
      "required": [
        "name",
        "sections"
      ],
      "additionalProperties": false
    },
    "AppCardsSection": {
      "id": "AppCardsSection",
      "type": "object",
      "properties": {
        "tagline": {
          "type": "string"
        },
        "cards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AppCard"
          }
        }
      },
      "required": [
        "tagline",
        "cards"
      ],
      "additionalProperties": false
    },
    "AppCard": {
      "id": "AppCard",
      "type": "object",
      "properties": {
        "tagline": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "imagePath": {
          "type": "string"
        },
        "logoPath": {
          "type": "string"
        },
        "appStatus": {
          "type": "string",
          "enum": [
            "Preview",
            "Alpha",
            "Beta"
          ]
        },
        "appUrl": {
          "type": "string"
        },
        "documentLink": {
          "type": "string"
        }
      },
      "required": [
        "tagline",
        "description",
        "imagePath",
        "logoPath",
        "appUrl",
        "documentLink"
      ],
      "additionalProperties": false
    }
  }
}
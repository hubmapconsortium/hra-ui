{
  "name": "asctb-reporter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/asctb-reporter/src",
  "prefix": "app",
  "tags": ["type:app", "project:asctb"],
  "metadata": {
    "version": "4.1.0"
  },
  "targets": {
    "build": {
      "executor": "@nx/angular:application",
      "options": {
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/asctb-reporter/public"
          },
          {
            "input": "libs/design-system/assets",
            "glob": "**/*",
            "output": "./assets"
          }
        ],
        "polyfills": ["zone.js"],
        "styles": ["apps/asctb-reporter/src/styles.scss", "node_modules/jspreadsheet-ce/dist/jspreadsheet.css"]
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/asctb-reporter/src/environments/environment.ts",
              "with": "apps/asctb-reporter/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "10kb"
            }
          ]
        },
        "staging": {
          "fileReplacements": [
            {
              "replace": "apps/asctb-reporter/src/environments/environment.ts",
              "with": "apps/asctb-reporter/src/environments/environment.staging.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "executor": "@nx/angular:dev-server"
    }
  }
}

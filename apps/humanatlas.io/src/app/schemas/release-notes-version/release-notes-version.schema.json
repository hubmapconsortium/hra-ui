{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "ReleaseNotesVersions",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "versions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ReleaseNotesVersion"
      }
    }
  },
  "required": [
    "$schema",
    "versions"
  ],
  "additionalProperties": false,
  "$defs": {
    "ReleaseNotesVersion": {
      "id": "ReleaseNotesVersion",
      "type": "object",
      "properties": {
        "version": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "date": {
          "type": "string"
        }
      },
      "required": [
        "version",
        "label",
        "date"
      ],
      "additionalProperties": false
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "LandingPageData",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "carouselItems": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CarouselItem"
      }
    },
    "countInfo": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "count": {
            "type": "number"
          },
          "label": {
            "type": "string"
          },
          "suffix": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          }
        },
        "required": [
          "count",
          "label",
          "icon"
        ],
        "additionalProperties": false
      }
    },
    "sectionCardInfo": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SectionCardItem"
      }
    }
  },
  "required": [
    "$schema",
    "carouselItems",
    "countInfo",
    "sectionCardInfo"
  ],
  "additionalProperties": false,
  "$defs": {
    "CarouselItem": {
      "id": "CarouselItem",
      "type": "object",
      "properties": {
        "tagline": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "imageSrc": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "link": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "required": [
                "url"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "route": {
                  "type": "string"
                }
              },
              "required": [
                "route"
              ],
              "additionalProperties": false
            }
          ]
        }
      },
      "required": [
        "tagline",
        "description",
        "imageSrc",
        "action",
        "link"
      ],
      "additionalProperties": false
    },
    "SectionCardItem": {
      "id": "SectionCardItem",
      "type": "object",
      "properties": {
        "tagline": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "route": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "action": {
          "type": "string"
        }
      },
      "required": [
        "tagline",
        "icon",
        "action"
      ],
      "additionalProperties": false
    }
  }
}
{
  "name": "ftu-ui-small-wc",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "hra",
  "sourceRoot": "apps/ftu-ui-small-wc/src",
  "tags": ["type:app", "project:ftu"],
  "metadata": {
    "version": "0.6.0"
  },
  "targets": {
    "build": {
      "executor": "@nx/angular:application",
      "options": {
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/ftu-ui-small-wc/public"
          },
          {
            "input": "libs/design-system/assets",
            "glob": "**/*",
            "output": "./assets"
          }
        ],
        "polyfills": ["zone.js"]
      },
      "configurations": {
        "staging": {
          "fileReplacements": [
            {
              "replace": "apps/ftu-ui-small-wc/src/environments/environment.ts",
              "with": "apps/ftu-ui-small-wc/src/environments/environment.staging.ts"
            }
          ]
        },
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/ftu-ui-small-wc/src/environments/environment.ts",
              "with": "apps/ftu-ui-small-wc/src/environments/environment.prod.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "executor": "@nx/angular:dev-server"
    },
    "compodoc": {
      "executor": "@twittwer/compodoc:compodoc",
      "options": {
        "tsConfig": "apps/ftu-ui-small-wc/tsconfig.app.json"
      }
    },
    "build-webcomponent": {
      "command": "node tools/scripts/bundle-scripts.mjs dist/apps/ftu-ui-small-wc/browser/"
    }
  }
}

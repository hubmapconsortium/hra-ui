{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "HeaderMenus",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "options": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "$ref": "#/$defs/HeaderMenu"
          },
          {
            "$ref": "#/$defs/HeaderMenuItem"
          }
        ]
      }
    }
  },
  "required": [
    "$schema",
    "options"
  ],
  "additionalProperties": false,
  "$defs": {
    "HeaderMenu": {
      "id": "HeaderMenu",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "menu"
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/HeaderMenuGroup"
          }
        },
        "featured": {
          "$ref": "#/$defs/HeaderMenuItem"
        }
      },
      "required": [
        "type",
        "id",
        "label"
      ],
      "additionalProperties": false
    },
    "HeaderMenuGroup": {
      "id": "HeaderMenuGroup",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "group"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "external": {
          "type": "boolean"
        },
        "target": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/HeaderMenuItem"
          }
        }
      },
      "required": [
        "type",
        "label",
        "items"
      ],
      "additionalProperties": false
    },
    "HeaderMenuItem": {
      "id": "HeaderMenuItem",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "item"
        },
        "label": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "tagline": {
          "type": "string"
        },
        "imgSrc": {
          "type": "string"
        },
        "external": {
          "type": "boolean"
        },
        "target": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "label",
        "url"
      ],
      "additionalProperties": false
    }
  }
}
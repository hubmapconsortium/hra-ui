{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/ContentPageData",
  "$defs": {
    "ContentPageData": {
      "id": "ContentPageData",
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "icons": {
          "$ref": "#/$defs/IconList"
        },
        "action": {
          "type": "object",
          "properties": {
            "label": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "label",
            "url"
          ],
          "additionalProperties": false
        },
        "headerContent": {
          "$ref": "#/$defs/ProjectedContentTemplate"
        },
        "content": {
          "$ref": "#/$defs/ProjectedContentTemplate"
        }
      },
      "required": [
        "$schema",
        "title",
        "subtitle",
        "content"
      ],
      "additionalProperties": false
    },
    "IconList": {
      "id": "IconList",
      "anyOf": [
        {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/IconData"
            }
          ]
        },
        {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/$defs/IconData"
              }
            ]
          }
        }
      ]
    },
    "IconData": {
      "id": "IconData",
      "type": "object",
      "properties": {
        "svgIcon": {
          "type": "string"
        },
        "fontIcon": {
          "type": "string"
        },
        "fontSet": {
          "type": "string"
        },
        "inline": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "ProjectedContentTemplate": {
      "id": "ProjectedContentTemplate",
      "anyOf": [
        {
          "$ref": "#/$defs/AnyContentTemplate"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AnyContentTemplate"
          }
        }
      ]
    },
    "AnyContentTemplate": {
      "id": "AnyContentTemplate",
      "oneOf": [
        {
          "$ref": "#/$defs/ActionCard"
        },
        {
          "$ref": "#/$defs/ApiCommand"
        },
        {
          "$ref": "#/$defs/Button"
        },
        {
          "$ref": "#/$defs/CodeBlock"
        },
        {
          "$ref": "#/$defs/DataViewer"
        },
        {
          "$ref": "#/$defs/FlexContainer"
        },
        {
          "$ref": "#/$defs/GridContainer"
        },
        {
          "$ref": "#/$defs/Icon"
        },
        {
          "$ref": "#/$defs/Image"
        },
        {
          "$ref": "#/$defs/Markdown"
        },
        {
          "$ref": "#/$defs/PageSection"
        },
        {
          "$ref": "#/$defs/Table"
        },
        {
          "$ref": "#/$defs/ProfileCard"
        },
        {
          "$ref": "#/$defs/TextHyperlink"
        },
        {
          "$ref": "#/$defs/VersionedDataTable"
        },
        {
          "$ref": "#/$defs/YouTubePlayer"
        }
      ]
    },
    "ActionCard": {
      "id": "ActionCard",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "ActionCard"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "variant": {
          "$ref": "#/$defs/ActionCardVariant"
        },
        "tagline": {
          "type": "string"
        },
        "subtagline": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "icons": {
          "$ref": "#/$defs/IconList"
        },
        "content": {
          "$ref": "#/$defs/ProjectedContentTemplate"
        },
        "actionsLeft": {
          "$ref": "#/$defs/ProjectedContentTemplate"
        },
        "actionsRight": {
          "$ref": "#/$defs/ProjectedContentTemplate"
        }
      },
      "required": [
        "component",
        "variant",
        "tagline"
      ],
      "additionalProperties": false
    },
    "Classes": {
      "id": "Classes",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      ]
    },
    "Styles": {
      "id": "Styles",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      ]
    },
    "Controller": {
      "id": "Controller",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        }
      },
      "required": [
        "id"
      ],
      "additionalProperties": {}
    },
    "ActionCardVariant": {
      "id": "ActionCardVariant",
      "type": "string",
      "enum": [
        "elevated",
        "flat",
        "outlined",
        "outlined-with-icons"
      ]
    },
    "ApiCommand": {
      "id": "ApiCommand",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "ApiCommand"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "request": {
          "type": "string"
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST"
          ]
        },
        "rightButton": {
          "$ref": "#/$defs/ApiCommandButton"
        }
      },
      "required": [
        "component",
        "request",
        "method",
        "rightButton"
      ],
      "additionalProperties": false
    },
    "ApiCommandButton": {
      "id": "ApiCommandButton",
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "label"
      ],
      "additionalProperties": false
    },
    "Button": {
      "id": "Button",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "Button"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "label": {
          "type": "string"
        },
        "href": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "default",
            "flat",
            "cta",
            "fab"
          ]
        },
        "variant": {
          "type": "string",
          "enum": [
            "primary",
            "secondary"
          ]
        },
        "size": {
          "type": "string",
          "enum": [
            "small",
            "medium"
          ]
        },
        "disabled": {
          "type": "boolean"
        },
        "icon": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "label",
        "href"
      ],
      "additionalProperties": false
    },
    "CodeBlock": {
      "id": "CodeBlock",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "CodeBlock"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "code": {
          "type": "string"
        },
        "language": {
          "type": "string"
        }
      },
      "required": [
        "component"
      ],
      "additionalProperties": false
    },
    "DataViewer": {
      "id": "DataViewer",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "DataViewer"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "variant": {
          "$ref": "#/$defs/DataViewerVariant"
        },
        "githubIconsUrl": {
          "type": "string"
        },
        "releaseVersionData": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ReleaseVersionData"
          }
        }
      },
      "required": [
        "component",
        "variant",
        "githubIconsUrl",
        "releaseVersionData"
      ],
      "additionalProperties": false
    },
    "DataViewerVariant": {
      "id": "DataViewerVariant",
      "type": "string",
      "enum": [
        "ftu",
        "3d-organ"
      ]
    },
    "ReleaseVersionData": {
      "id": "ReleaseVersionData",
      "type": "object",
      "properties": {
        "version": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "crosswalkUrl": {
          "type": "string",
          "format": "uri"
        },
        "extractionsSitesUrl": {
          "type": "string",
          "format": "uri"
        },
        "referenceOrgansUrl": {
          "type": "string",
          "format": "uri"
        },
        "organData": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DataViewerOrgan"
          }
        }
      },
      "required": [
        "version",
        "label",
        "date",
        "organData"
      ],
      "additionalProperties": false
    },
    "DataViewerOrgan": {
      "id": "DataViewerOrgan",
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "cards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DataViewerCard"
          }
        }
      },
      "required": [
        "label",
        "icon",
        "cards"
      ],
      "additionalProperties": false
    },
    "DataViewerCard": {
      "id": "DataViewerCard",
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        },
        "fileUrl": {
          "type": "string",
          "format": "uri"
        },
        "sourceDataUrl": {
          "type": "string",
          "format": "uri"
        },
        "fullscreenUrl": {
          "type": "string",
          "format": "uri"
        },
        "crosswalkUrl": {
          "type": "string",
          "format": "uri"
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DataViewerFile"
          }
        }
      },
      "required": [
        "label",
        "fileUrl",
        "sourceDataUrl",
        "files"
      ],
      "additionalProperties": false
    },
    "DataViewerFile": {
      "id": "DataViewerFile",
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "label",
        "url"
      ],
      "additionalProperties": false
    },
    "FlexContainer": {
      "id": "FlexContainer",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "FlexContainer"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "rowGap": {
          "type": "string"
        },
        "columnGap": {
          "type": "string"
        },
        "content": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AnyContentTemplate"
          }
        }
      },
      "required": [
        "component",
        "content"
      ],
      "additionalProperties": false
    },
    "GridContainer": {
      "id": "GridContainer",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "GridContainer"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "itemMinWidth": {
          "type": "string"
        },
        "content": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AnyContentTemplate"
          }
        }
      },
      "required": [
        "component",
        "content"
      ],
      "additionalProperties": false
    },
    "Icon": {
      "id": "Icon",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "Icon"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "svgIcon": {
          "type": "string"
        },
        "fontIcon": {
          "type": "string"
        },
        "fontSet": {
          "type": "string"
        },
        "inline": {
          "type": "boolean"
        }
      },
      "required": [
        "component"
      ],
      "additionalProperties": false
    },
    "Image": {
      "id": "Image",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "Image"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "src": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "src"
      ],
      "additionalProperties": false
    },
    "Markdown": {
      "id": "Markdown",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "Markdown"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "data": {
          "type": "string"
        },
        "src": {
          "type": "string"
        }
      },
      "required": [
        "component"
      ],
      "additionalProperties": false
    },
    "PageSection": {
      "id": "PageSection",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "PageSection"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "tagline": {
          "type": "string"
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "icons": {
          "$ref": "#/$defs/IconList"
        },
        "anchor": {
          "type": "string"
        },
        "content": {
          "$ref": "#/$defs/ProjectedContentTemplate"
        }
      },
      "required": [
        "component",
        "tagline",
        "content"
      ],
      "additionalProperties": false
    },
    "Table": {
      "id": "Table",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "PageTable"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "csvUrl": {
          "type": "string"
        },
        "columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TableColumn"
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TableRow"
          }
        },
        "style": {
          "$ref": "#/$defs/TableVariant"
        },
        "enableSort": {
          "type": "boolean"
        },
        "verticalDividers": {
          "type": "boolean"
        },
        "enableSelection": {
          "type": "boolean"
        }
      },
      "required": [
        "component"
      ],
      "additionalProperties": false
    },
    "TableColumn": {
      "id": "TableColumn",
      "type": "object",
      "properties": {
        "column": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "type": {
          "default": "text",
          "anyOf": [
            {
              "anyOf": [
                {
                  "type": "string",
                  "const": "text"
                },
                {
                  "type": "string",
                  "const": "numeric"
                },
                {
                  "type": "string",
                  "const": "markdown"
                },
                {
                  "type": "string",
                  "const": "icon"
                },
                {
                  "type": "string",
                  "const": "menu"
                }
              ]
            },
            {
              "anyOf": [
                {
                  "$ref": "#/$defs/TextColumnType"
                },
                {
                  "$ref": "#/$defs/NumericColumnType"
                },
                {
                  "$ref": "#/$defs/MarkdownColumnType"
                },
                {
                  "$ref": "#/$defs/LinkColumnType"
                },
                {
                  "$ref": "#/$defs/IconColumnType"
                },
                {
                  "$ref": "#/$defs/MenuButtonColumnType"
                }
              ]
            }
          ]
        }
      },
      "required": [
        "column",
        "label",
        "type"
      ],
      "additionalProperties": false
    },
    "TextColumnType": {
      "id": "TextColumnType",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "text"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "NumericColumnType": {
      "id": "NumericColumnType",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "numeric"
        },
        "computeTotal": {
          "type": "boolean"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "MarkdownColumnType": {
      "id": "MarkdownColumnType",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "markdown"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "LinkColumnType": {
      "id": "LinkColumnType",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "link"
        },
        "urlColumn": {
          "type": "string"
        },
        "internal": {
          "type": "boolean"
        }
      },
      "required": [
        "type",
        "urlColumn"
      ],
      "additionalProperties": false
    },
    "IconColumnType": {
      "id": "IconColumnType",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "icon"
        },
        "icon": {
          "type": "string"
        },
        "tooltip": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "icon"
      ],
      "additionalProperties": false
    },
    "MenuButtonColumnType": {
      "id": "MenuButtonColumnType",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "menu"
        },
        "icon": {
          "type": "string"
        },
        "options": {
          "type": "string"
        },
        "tooltip": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "icon",
        "options"
      ],
      "additionalProperties": false
    },
    "TableRow": {
      "id": "TableRow",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          },
          {
            "type": "array",
            "items": {}
          }
        ]
      }
    },
    "TableVariant": {
      "id": "TableVariant",
      "type": "string",
      "enum": [
        "alternating",
        "divider",
        "basic"
      ]
    },
    "ProfileCard": {
      "id": "ProfileCard",
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "const": "ProfileCard"
        },
        "classes": {
          "$ref": "#/$defs/Classes"
        },
        "styles": {
          "$ref": "#/$defs/Styles"
        },
        "controllers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Controller"
          }
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "pictureUrl": {
          "type": "string"
        },
        "centerContent": {
          "type": "boolean"
        },
        "actions": {
          "$ref": "#/$defs/ProjectedContentTemplate"
        }
      },
      "required": [
        "component",
        "name",
